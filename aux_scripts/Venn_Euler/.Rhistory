install.packages("VennDiagram")

library(VennDiagram)
liver_species <- scan("Liver_Krona_species_list.txt", what="", sep="\n")
telencephalon_species <- scan("Telencephalon_Krona_species_list.txt", what="", sep="\n")
venn.plot <- venn.diagram(
  x = list(Liver = liver_species, Telencephalon = telencephalon_species),
  category.names = c("Liver", "Telencephalon"),
  filename = "venn_diagram.png",
  output = TRUE
)

# Salvar o gráfico
grid.draw(venn.plot)
# Carregar o pacote VennDiagram
library(VennDiagram)

# Carregar as listas de espécies dos arquivos
liver_species <- scan("Liver_Krona_species_list.txt", what="", sep="\n")
telencephalon_species <- scan("Telencephalon_Krona_species_list.txt", what="", sep="\n")

# Criar o diagrama de Venn
venn.plot <- venn.diagram(
  x = list(Liver = liver_species, Telencephalon = telencephalon_species),
  category.names = c("Liver", "Telencephalon"),
  filename = NULL  # Não salvar diretamente em arquivo
)

# Desenhar o gráfico diretamente no dispositivo gráfico
grid.newpage()
grid.draw(venn.plot)

# Se quiser salvar o gráfico manualmente depois
tiff("venn_diagram.tiff")
grid.draw(venn.plot)
dev.off()

q()
